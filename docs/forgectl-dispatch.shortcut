		</dict>
		<dict>
			<key>ActionIndex</key>
			<integer>5</integer>
			<key>Category</key>
			<string>Parameter</string>
			<key>DefaultValue</key>
			<string>Bearer YOUR_DAEMON_TOKEN</string>
			<key>ParameterKey</key>
			<string>WFHTTPHeaders.Value.WFDictionaryFieldValueItems.0.WFValue</string>
			<key>Text</key>
			<string>Enter your daemon token (Bearer &lt;token&gt;). Find it at ~/.forgectl/daemon.token</string>
		</dict>
	</array>
	<key>WFWorkflowTypes</key>
	<array>
		<string>NCWidget</string>
		<string>WatchKit</string>
	</array>
